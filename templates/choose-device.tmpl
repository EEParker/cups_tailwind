<h2 class="text-base font-semibold mb-4">{op=modify-printer?Modify {printer_name}:Add printer}</h2>

{CUPS_GET_DEVICES_DONE?
<form method="POST" action="/admin" class="space-y-5">
  <input type="hidden" name="org.cups.sid" value="{$org.cups.sid}">
  <input type="hidden" name="OP" value="{op}">
  {printer_name?<input type="hidden" name="printer_name" value="{printer_name}">:}

  {op=add-printer?:
  <fieldset class="card p-4">
    <legend class="text-xs uppercase tracking-wide font-medium px-1 text-(--color-fg-muted)">Current connection</legend>
    <label class="flex items-start gap-2 text-sm">
      <input type="radio" name="DEVICE_URI" value="{current_device_uri}" checked class="mt-1">
      <span class="font-mono text-xs break-all">{current_device_uri}</span>
    </label>
  </fieldset>}

  <fieldset class="card p-4">
    <legend class="text-xs uppercase tracking-wide font-medium px-1 text-(--color-fg-muted)">Local printers</legend>
    <div class="space-y-1.5 text-sm">
      {[device_uri]{device_class!network?
      <label class="flex items-start gap-2">
        <input type="radio" name="DEVICE_URI" value="{device_uri}{?device_make_and_model!Unknown?|{device_make_and_model}:}" class="mt-1">
        <span>{device_info} {?device_make_and_model!Unknown?<span class="text-(--color-fg-subtle)">({device_make_and_model})</span>:}</span>
      </label>:}}
    </div>
  </fieldset>

  <fieldset class="card p-4">
    <legend class="text-xs uppercase tracking-wide font-medium px-1 text-(--color-fg-muted)">Discovered network printers</legend>
    <div class="space-y-1.5 text-sm">
      {[device_uri]{device_class=network?{device_uri~[a-z]+://?
      <label class="flex items-start gap-2">
        <input type="radio" name="DEVICE_URI" value="{device_uri}{?device_make_and_model!Unknown?|{device_make_and_model}:}" class="mt-1">
        <span>{device_info} {?device_make_and_model!Unknown?<span class="text-(--color-fg-subtle)">({device_make_and_model})</span>:}</span>
      </label>:}:}}
    </div>
  </fieldset>

  <fieldset class="card p-4">
    <legend class="text-xs uppercase tracking-wide font-medium px-1 text-(--color-fg-muted)">Other network printers</legend>
    <div class="space-y-1.5 text-sm">
      {[device_uri]{device_class=network?{device_uri~[a-z]+://?:
      <label class="flex items-start gap-2">
        <input type="radio" name="DEVICE_URI" value="{device_uri}{?device_make_and_model!Unknown?|{device_make_and_model}:}" class="mt-1">
        <span>{device_info} {?device_make_and_model!Unknown?<span class="text-(--color-fg-subtle)">({device_make_and_model})</span>:}</span>
      </label>}:}}
    </div>
  </fieldset>

  <div><input type="submit" class="btn btn-primary" value="Continue"></div>
</form>:
<div class="card p-5 text-sm flex items-center gap-3 text-(--color-fg-muted)">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="animate-spin"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
  Looking for printers…
</div>}
